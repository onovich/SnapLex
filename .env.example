# SnapLex local provider configuration example.
# Copy values into your shell environment or a local ignored .env loader.
# Do not commit real API keys. Use separate private-trial keys with the lowest
# practical quota, budget, and access.

# Fake is deterministic smoke/dev mode only. It is not real translation.
SNAPLEX_PROVIDER=fake
SNAPLEX_PROVIDER_ORDER=fake
SNAPLEX_SOURCE_LANG=auto
SNAPLEX_TARGET_LANG=en

# LibreTranslate can run without a key on many self-hosted instances.
SNAPLEX_LIBRETRANSLATE_BASE_URL=http://localhost:5000
SNAPLEX_LIBRETRANSLATE_API_KEY_ENV=
SNAPLEX_LIBRETRANSLATE_CREDENTIAL_SOURCE=
SNAPLEX_LIBRETRANSLATE_CREDENTIAL_IDENTIFIER=
SNAPLEX_LIBRETRANSLATE_TIMEOUT_SECONDS=10
SNAPLEX_LIBRETRANSLATE_RETRY_COUNT=0
# SNAPLEX_LIBRETRANSLATE_API_KEY=

# OpenAI stores the env var name in config and reads the secret at request time.
SNAPLEX_OPENAI_BASE_URL=https://api.openai.com/v1
SNAPLEX_OPENAI_API_KEY_ENV=SNAPLEX_OPENAI_API_KEY
SNAPLEX_OPENAI_CREDENTIAL_SOURCE=
SNAPLEX_OPENAI_CREDENTIAL_IDENTIFIER=
SNAPLEX_OPENAI_TIMEOUT_SECONDS=20
SNAPLEX_OPENAI_RETRY_COUNT=0
SNAPLEX_OPENAI_MODEL=gpt-5.5
# SNAPLEX_OPENAI_API_KEY=

# DeepL free endpoint is the default. Use https://api.deepl.com/v2 for Pro.
SNAPLEX_DEEPL_BASE_URL=https://api-free.deepl.com/v2
SNAPLEX_DEEPL_API_KEY_ENV=SNAPLEX_DEEPL_API_KEY
SNAPLEX_DEEPL_CREDENTIAL_SOURCE=
SNAPLEX_DEEPL_CREDENTIAL_IDENTIFIER=
SNAPLEX_DEEPL_TIMEOUT_SECONDS=20
SNAPLEX_DEEPL_RETRY_COUNT=0
SNAPLEX_DEEPL_MODEL_TYPE=
# SNAPLEX_DEEPL_API_KEY=

# To use the optional OS keyring path, install .[credentials], set
# SNAPLEX_<PROVIDER>_CREDENTIAL_SOURCE=keyring, set a non-secret identifier
# such as snaplex/openai/default, then save the actual key through Settings.
